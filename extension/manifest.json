      "run_at": "document_idle",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "https://*.youtube.com/live_chat*"
      ],
      "exclude_matches": [
        "https://m.youtube.com/*",
        "https://studio.youtube.com/*"
      ],
      "js": [
        "core/env.js",
        "core/storage.js",
        "core/styles.js",
        "core/registry.js",
        "core/runtime-flags.js",
        "core/capability-probe.js",
        "core/selector-packs/appShell.js",
        "core/selector-packs/nav.js",
