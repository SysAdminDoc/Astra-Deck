{
  "private": true,
  "name": "astra-deck",
  "version": "4.46.6",
  "description": "Chrome/Firefox MV3 extension and Tampermonkey userscript for YouTube enhancement",
  "author": "SysAdminDoc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SysAdminDoc/Astra-Deck.git"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node build-extension.js",
    "build:userscript": "node build-extension.js --with-userscript",
    "release:manifest": "node scripts/generate-release-manifest.js",
    "release:readiness": "node scripts/generate-release-readiness.js",
    "release:verify-digests": "node scripts/compare-release-digests.js",
    "release:stage-companion": "node scripts/stage-companion-release.js",
    "policy:actions": "node scripts/generate-actions-policy.js",
    "build:fixtures": "node scripts/build-selector-fixtures.js",
    "i18n:coverage": "node scripts/i18n-coverage.js",
    "i18n:coverage:warn": "node scripts/i18n-coverage.js --warn-feature-identical-above 582",
    "i18n:coverage:gate": "node scripts/i18n-coverage.js --no-write --fail-above 688",
    "i18n:proofing-export": "node scripts/export-i18n-proofing.js",
    "audit:storage": "node scripts/audit-storage-size.js",
    "capture:watch": "node scripts/capture-watch-mhtml.js",
    "capture:surface": "node scripts/capture-watch-mhtml.js",
    "check": "node scripts/check-syntax.js && node scripts/check-versions.js && node scripts/check-i18n.js && node scripts/check-settings.js && node scripts/check-no-eval.js && node scripts/check-firefox-injection.js && node scripts/check-userscript-drift.js && npm run check:firefox && npm run lint && npm run audit:a11y && npm run audit:overlays && npm run audit:contrast && npm run audit:deps && npm run i18n:coverage:gate",
    "audit:deps": "npm audit --omit=dev --audit-level=moderate",
    "check:versions": "node scripts/check-versions.js",
    "check:settings": "node scripts/check-settings.js",
    "lint": "eslint extension/background.js extension/popup.js extension/core/*.js extension/ytkit.js",
    "check:firefox": "node scripts/check-firefox-webext.js",
    "smoke:firefox": "node scripts/smoke-firefox-webext.js",
    "smoke:optional-hosts": "node scripts/smoke-chromium-optional-hosts.js",
    "audit:a11y": "node scripts/audit-popup-a11y.js",
    "audit:overlays": "node scripts/audit-overlays-a11y.js",
    "audit:contrast": "node scripts/check-contrast.js",
    "test": "node --test tests/*.test.js tests/features/*.test.js"
  },
  "dependencies": {
    "crx3": "^2.0.0"
  },
  "devDependencies": {
    "eslint": "^10.2.1",
    "web-ext": "10.4.0",
    "ws": "8.21.0"
  }
}
